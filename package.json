{
  "name": "revops-automation-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "dev:db": "supabase start",
    "dev:redis": "echo 'Using Upstash Redis - no local server needed!'",
    "dev:full": "concurrently \"npm run dev:db\" \"npm run dev:redis\" \"npm run dev\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "playwright test",
    "db:setup": "supabase db push && npm run db:seed",
    "db:seed": "node -r esbuild-register scripts/seed-database.ts",
    "db:reset": "supabase db reset && npm run db:setup",
    "db:types": "supabase gen types typescript --linked > lib/types/supabase.ts",
    "migration:new": "supabase migration new",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.2",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-table": "^8.21.3",
    "@types/bull": "^4.10.0",
    "@types/express": "^4.17.21",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash": "^4.14.202",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@upstash/redis": "^1.35.6",
    "axios": "^1.7.7",
    "bull": "^4.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^8.2.2",
    "date-fns": "^3.0.6",
    "dotenv": "^17.2.3",
    "esbuild-register": "^3.5.0",
    "express": "^4.18.2",
    "framer-motion": "^12.23.24",
    "husky": "^8.0.3",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lint-staged": "^15.2.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.441.0",
    "next": "^14.2.33",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "redis": "^4.6.11",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8.4.41",
    "supabase": "^1.148.0",
    "tailwindcss": "^3.4.9",
    "ts-jest": "^29.1.1",
    "typescript": "^5.5.4"
  }
}
